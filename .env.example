# ============================
# Agent Configuration
# ============================

# Your DeepSeek API key (get it from https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Your CockroachDB connection URL (PostgreSQL wire-compatible)
COCKROACHDB_URL=postgresql://your-user:your-password@your-cluster.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full

# LLM model to use — LiteLLM format: "deepseek/<model-id>" or any provider/model
# Change this anytime to swap models without touching code
LLM_MODEL=deepseek/deepseek-v4-flash

# Sentry DSN for error tracking (get it from sentry.io project settings)
SENTRY_DSN=https://your-dsn-here@oXXX.ingest.sentry.io/XXX

# SMTP Configuration (for sending job application emails)
SMTP_EMAIL=your-gmail-address@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Path to your resume PDF (optional, used for auto-loading on startup)
RESUME_PDF_PATH=/path/to/your/resume.pdf

# TinyFish API key for web search and job discovery (get from tinyfish.ai)
TINYFISH_API_KEY=your-tinyfish-api-key

# ============================
# Advanced Configuration
# ============================

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
DAILY_BUDGET_USD=5.0

# Database connection pool
DB_POOL_MINCONN=1
DB_POOL_MAXCONN=5
DB_MAX_RETRIES=3
DB_RETRY_DELAY=2.0

# Tool execution
TOOL_MAX_RETRIES=2
